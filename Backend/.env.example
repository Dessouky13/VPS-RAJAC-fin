# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rajac
POSTGRES_USER=rajac
POSTGRES_PASSWORD=your_strong_db_password_here

# ── Authentication ─────────────────────────────────────────────────────────────
# Must be at least 32 random characters — generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_64_char_secret

# ── Default user credentials (used only on first startup if DB has no users) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2025
HR_USERNAME=hr
HR_PASSWORD=Hr@2025

# ── School settings ────────────────────────────────────────────────────────────
SCHOOL_NAME=RAJAC Language School
PORT=3000
NODE_ENV=production

# ── Frontend origin (for CORS) ─────────────────────────────────────────────────
FRONTEND_URL=https://rajac-fin.vercel.app
